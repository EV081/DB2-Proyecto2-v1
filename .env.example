POSTGRES_DB=proyecto2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<coloca-tu-password-local>
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:<coloca-tu-password-local>@localhost:5433/proyecto2

# ===== Datasets (todos los valores tienen default razonable; cambia solo si hace falta) =====

# jam-alt (HuggingFace, sin auth)
JAMALT_HF_DATASET=jamendolyrics/jam-alt
JAMALT_LANGUAGE=en
JAMALT_SPLIT=test

# FMA small (HTTPS directo, sin auth)
FMA_SMALL_URL=https://os.unil.cloud.switch.ch/fma/fma_small.zip
FMA_SMALL_SHA1=ade154f733639d52e35e32f5593efe5be76c6d70

# Kaggle (Spotify lyrics + Fashion images)
SPOTIFY_KAGGLE_DATASET=imuhammad/audio-features-and-lyrics-of-spotify-songs
FASHION_KAGGLE_DATASET=paramaggarwal/fashion-product-images-dataset

# ===== Kaggle auth =====
# Único campo realmente obligatorio para habilitar Spotify/Fashion.
# Genera en https://www.kaggle.com/settings -> API -> Create New Token.
# Formato nuevo: empieza con "KGAT_..."
# Si lo dejas vacío, setup_all.sh saltea Spotify y Fashion silenciosamente.
KAGGLE_API_TOKEN=
